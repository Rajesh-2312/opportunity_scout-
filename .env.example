# =============================================
# OPPORTUNITY SCOUT — COMPLETE CONFIGURATION
# Copy this file to .env and fill in your keys
# =============================================

# ── PHASE 1: AI BRAIN (FREE via NVIDIA NIM) ──
# Get free key from: https://build.nvidia.com (OpenAI-compatible API)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use (free on NVIDIA NIM) — 8b is fast/reliable, 70b is slower
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ── PHASE 1: WHAT TO SCAN ────────────────────
TARGET_SECTORS=infrastructure,energy,ports,logistics,airports,green hydrogen,cement,data center
TARGET_STATES=Andhra Pradesh,Telangana,Karnataka,Tamil Nadu,Maharashtra
MIN_TENDER_VALUE_LAKHS=10
SCAN_INTERVAL_HOURS=6

# ── PHASE 2: TELEGRAM NOTIFICATIONS (FREE) ───
# Step 1: Message @BotFather on Telegram → /newbot → copy the FULL token (123456789:AAH...)
# Step 2: Message @userinfobot → copy your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: proxy to reach Telegram if your ISP blocks it (HTTP/HTTPS proxy URL)
# e.g. http://user:pass@host:port  — leave blank if using a VPN instead
TELEGRAM_PROXY=

# ── PHASE 2: TELEGRAM PUBLIC CHANNEL ─────────
# HOW TO SET UP:
#   1. Open Telegram → tap pencil icon → New Channel
#   2. Name: "India Infra Intelligence"
#   3. Set to PUBLIC → pick a username e.g. IndiaInfraScout
#   4. Go to channel settings → Administrators → Add your bot as admin
#   5. Copy username below (with @) or numeric ID -100xxxxxxxxx
TELEGRAM_CHANNEL_ID=@opportunity_scout  

# ── PHASE 2: PAYMENTS ────────────────────────
# HOW TO SET UP RAZORPAY (FREE):
#   1. Go to https://razorpay.com → Sign up (needs PAN + bank account)
#   2. Dashboard → Payment Links → Create Payment Link
#   3. Amount: 299 | Description: "India Infra Intelligence — Monthly Premium"
#   4. Enable "Allow customers to change amount" (for pro/enterprise upgrades)
#   5. Copy your link (looks like https://rzp.io/l/xxxxx)
RAZORPAY_PAYMENT_LINK=https://rzp.io/l/your-link

# ── PHASE 2: NEWSLETTER IDENTITY ─────────────
AUTHOR_NAME=Rajesh M.
NEWSLETTER_NAME=India Infra Intelligence
SUBSTACK_URL=https://your.substack.com
LINKEDIN_URL=https://linkedin.com/in/your-profile

# ── PHASE 5: DASHBOARD ───────────────────────
DASHBOARD_PORT=8000
